{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_APP_URL": {
      "description": "Public app URL (auto-set by Vercel)"
    },
    "JWT_SECRET": {
      "description": "JWT secret for authentication"
    },
    "DATABASE_URL": {
      "description": "Turso DB connection string (libsql://...)"
    },
    "DATABASE_AUTH_TOKEN": {
      "description": "Turso auth token"
    }
  }
}
