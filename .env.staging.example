# GoalGetter App — Staging Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit the actual .env file

# ===========================================
# REQUIRED — Application will not start without these
# ===========================================

# Database connection (Turso cloud instance for staging)
DATABASE_URL=libsql://your-db-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# JWT Secret Key (generate with: openssl rand -base64 44)
# Must be >= 32 characters
JWT_SECRET=your-staging-jwt-secret-here-min-32-chars

# ===========================================
# REQUIRED — Application Configuration
# ===========================================

# Public URL (used for redirects, CORS)
NEXT_PUBLIC_APP_URL=https://staging.goalgetterapp.com

# Node environment
NODE_ENV=production

# ===========================================
# OPTIONAL — Defaults provided
# ===========================================

# Server port (default: 3000)
# PORT=3000
